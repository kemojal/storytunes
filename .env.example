# =============================================================================
# StoryTunes — shared environment reference
# =============================================================================
# Both apps connect to the SAME Neon Postgres database.
#   - apps/web : owns the AUTH tables (better-auth + drizzle migrations)
#   - apps/api : owns the BUSINESS tables (SQLAlchemy + alembic migrations)
#
# Copy the relevant block into:
#   apps/web/.env.local
#   apps/api/.env
# =============================================================================

# ---- Shared: Neon Postgres -------------------------------------------------
# Direct (unpooled) — use for migrations.
DATABASE_URL=postgresql://user:pass@ep-xxx.region.aws.neon.tech/storytunes?sslmode=require
# Pooled (PgBouncer) — use for serverless/runtime queries.
DATABASE_URL_POOLER=postgresql://user:pass@ep-xxx-pooler.region.aws.neon.tech/storytunes?sslmode=require

# ---- web: better-auth ------------------------------------------------------
BETTER_AUTH_SECRET=generate_with_openssl_rand_base64_32
BETTER_AUTH_URL=http://localhost:3000

# ---- web: Google OAuth -----------------------------------------------------
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ---- web: Stripe (better-auth stripe plugin) -------------------------------
# STRIPE_MODE is informational (test|live); the key prefix is the real mode.
STRIPE_MODE=test
STRIPE_SECRET_KEY=sk_test_xxx
STRIPE_WEBHOOK_SECRET=whsec_xxx
STRIPE_PUBLISHABLE_KEY=pk_test_xxx


# ---- web: Resend (email OTP + transactional) -------------------------------
RESEND_API_KEY=re_xxx
EMAIL_FROM="StoryTunes <hello@storytunes.example>"
TEST_EMAIL=kemo3855@gmail.com
# ---- web <-> api service-to-service ----------------------------------------
# web forwards verified Stripe payment events to api over this URL+key.
API_URL=http://localhost:8000
INTERNAL_API_KEY=generate_a_long_random_string

# ---- api only --------------------------------------------------------------
REDIS_URL=redis://localhost:6379/0
# Cloudflare R2 (S3-compatible)
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=storytunes
R2_PUBLIC_BASE_URL=



                                                                                                  
# ---- AI: lyrics (Gemini Flash) ----                                                                     
GEMINI_API_KEY=                                                                                           
GEMINI_MODEL=gemini-2.0-flash                                                                                                                                                                                   
# ---- AI: music generation ----                                                                          
# MUSIC_PROVIDER: stub | replicate | suno | elevenlabs                                                    
MUSIC_PROVIDER=stub                                                                                       
REPLICATE_API_TOKEN=                                                                                      
REPLICATE_MUSIC_MODEL=meta/musicgen                                                                       
SUNO_API_KEY=                                                                                             
SUNO_API_BASE=https://api.sunoapi.org                                                                     
ELEVENLABS_API_KEY=                                                                                                                                                                                               
# Run Celery tasks inline (no broker) — handy for local end-to-end testing.                               
CELERY_EAGER=false   