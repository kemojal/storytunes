# Neon Postgres (shared with web). Direct URL — alembic + runtime.
DATABASE_URL=postgresql://user:pass@ep-xxx.region.aws.neon.tech/storytunes?sslmode=require

# Celery broker/result backend
REDIS_URL=redis://localhost:6379/0

# web -> api shared secret (must match web's INTERNAL_API_KEY)
INTERNAL_API_KEY=dev_internal_key_change_me

# Stripe (api only verifies forwarded events; secret optional here)
STRIPE_SECRET_KEY=sk_test_xxx

# Resend (delivery emails)
RESEND_API_KEY=
EMAIL_FROM="StoryTunes <onboarding@resend.dev>"

# Cloudflare R2 (S3-compatible)
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=storytunes
R2_PUBLIC_BASE_URL=

# CORS — web origin
WEB_ORIGIN=http://localhost:3000
API_BASE_URL=http://localhost:8000

# ---- AI: lyrics (Gemini Flash) ----
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash

# ---- AI: music generation ----
# MUSIC_PROVIDER: ace | stub | lyria | replicate | suno | elevenlabs
MUSIC_PROVIDER=ace
# AceMusic (ACE-Step) — OpenAI-compatible; returns audio inline as base64.
ACE_MUSIC_API_KEY=
ACE_MUSIC_API_BASE=https://api.acemusic.ai
ACE_MUSIC_MODEL=acemusic/acestep-v1.5-turbo
# Other providers (paid):
LYRIA_MODEL=models/lyria-3-pro-preview   # uses GEMINI_API_KEY (paid tier)
REPLICATE_API_TOKEN=
REPLICATE_MUSIC_MODEL=meta/musicgen
SUNO_API_KEY=
SUNO_API_BASE=https://api.sunoapi.org
ELEVENLABS_API_KEY=

# Run Celery tasks inline (no broker) — handy for local end-to-end testing.
CELERY_EAGER=false
