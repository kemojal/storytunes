# Neon Postgres (shared with api). Use direct URL for drizzle migrations.
DATABASE_URL=
DATABASE_URL_POOLER=

# Better Auth
BETTER_AUTH_URL=http://localhost:3000
BETTER_AUTH_SECRET= # npx -y @better-auth/cli secret

# Google OAuth
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Stripe (better-auth stripe plugin)
# STRIPE_MODE is informational (test|live). The real mode is the key prefix —
# use sk_test_…/pk_test_… locally, sk_live_…/pk_live_… in production.
STRIPE_MODE=test
STRIPE_SECRET_KEY=sk_test_xxx
STRIPE_WEBHOOK_SECRET=whsec_xxx
STRIPE_PUBLISHABLE_KEY=pk_test_xxx

# Resend (email OTP + transactional)
RESEND_API_KEY=
EMAIL_FROM="StoryTunes <onboarding@resend.dev>"

# web -> api service-to-service
API_URL=http://localhost:8000
INTERNAL_API_KEY=

# Sentry / PostHog (optional, from cta scaffold)
VITE_SENTRY_DSN=
VITE_POSTHOG_KEY=
